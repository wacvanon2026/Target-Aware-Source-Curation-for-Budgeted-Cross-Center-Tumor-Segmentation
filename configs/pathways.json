{
  "pathways": [
    {
      "dataset": "MAMA-MIA",
      "task": "tumor_segmentation",
      "backend": "nnUNet",
      "config": "configs/mamamia_nnunet.json",
      "targets": ["NACT", "ISPY1", "DUKE", "ISPY2"],
      "budgets": [50, 150, 250],
      "selection_methods": ["random", "rds", "less", "orient", "craig", "gradmatch", "kmeans", "kcenter", "diversity"],
      "score_file_methods": ["rds", "less", "orient", "craig", "gradmatch", "kmeans", "kcenter", "diversity"],
      "selection_entrypoints": {
        "rds": "tavo_release.tavo",
        "less": "tavo_release.tavo",
        "orient": "tavo_release.tavo",
        "craig": "tavo_release.tavo",
        "gradmatch": "tavo_release.tavo",
        "kmeans": "tavo_release.tavo",
        "kcenter": "tavo_release.tavo",
        "diversity": "tavo_release.tavo"
      },
      "tavo_methods": ["tavo_8d_cmaes"],
      "tavo_entrypoints": ["python -m tavo_release.cli tavo-command --dataset mamamia"],
      "domain_adaptation_methods": ["dann", "mmd", "advent", "seasa"],
      "domain_adaptation_trainers": {
        "dann": "nnUNetTrainerTAVODANN",
        "mmd": "nnUNetTrainerTAVOMMD",
        "advent": "nnUNetTrainerTAVOADVENT",
        "seasa": "nnUNetTrainerTAVOSEASA"
      },
      "commands": {
        "split": "python -m tavo_release.cli split --dataset mamamia --data-root data/mamamia --output-root splits/mamamia_lodo_seed42",
        "plan": "python -m tavo_release.cli plan --dataset mamamia --output-dir outputs/plans",
        "collect": "python -m tavo_release.cli collect --dataset mamamia --results-root outputs/nnUNet_results --output outputs/mamamia_results.json"
      }
    },
    {
